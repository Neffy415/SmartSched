<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <%- include('../partials/theme-init') %>
    
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="app-container">
        <%- include('../partials/sidebar') %>

        <main class="main-content">
            <%- include('../partials/topbar') %>

            <div class="page-content">
                <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
                    <div class="alert alert-success animate-fade-in">
                        <i data-lucide="check-circle"></i>
                        <p><%= success_msg %></p>
                    </div>
                <% } %>

                <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
                    <div class="alert alert-error animate-fade-in">
                        <i data-lucide="alert-circle"></i>
                        <p><%= error_msg %></p>
                    </div>
                <% } %>

                <!-- Welcome Header -->
                <div class="page-header">
                    <div class="page-header-content">
                        <h1>Welcome back, <%= user.fullName ? user.fullName.split(' ')[0] : 'Student' %>! 👋</h1>
                        <p>Here's an overview of your study progress</p>
                    </div>
                    <a href="/study/start" class="btn btn-primary btn-lg">
                        <i data-lucide="play"></i>
                        Start Studying
                    </a>
                </div>

                <% if (activeSession) { %>
                    <!-- Active Session Banner -->
                    <div class="active-session-banner animate-pulse-border">
                        <div class="banner-content">
                            <div class="banner-icon">
                                <i data-lucide="loader" class="spinning"></i>
                            </div>
                            <div class="banner-info">
                                <h3>Active Session in Progress</h3>
                                <p>
                                    <span style="color: <%= activeSession.subject_color %>">
                                        <%= activeSession.subject_name %>
                                    </span> / <%= activeSession.topic_name %>
                                </p>
                            </div>
                        </div>
                        <a href="/study/active/<%= activeSession.id %>" class="btn btn-primary">
                            <i data-lucide="arrow-right"></i>
                            Continue Session
                        </a>
                    </div>
                <% } %>

                <!-- Stats Cards -->
                <div class="stats-grid stats-grid-4">
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                            <i data-lucide="clock"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-value"><%= Math.round(stats.minutesToday / 60 * 10) / 10 %>h</span>
                            <span class="stat-label">Study Time Today</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #14b8a6);">
                            <i data-lucide="zap"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-value"><%= stats.sessionsToday %></span>
                            <span class="stat-label">Sessions Today</span>
                        </div>
                    </div>
                    <div class="stat-card <%= parseInt(stats.overdueTasks) > 0 ? 'stat-warning' : '' %>">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #f97316);">
                            <i data-lucide="list-todo"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-value"><%= stats.pendingTasks %></span>
                            <span class="stat-label">Pending Tasks</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background: linear-gradient(135deg, #ec4899, #f43f5e);">
                            <i data-lucide="flame"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-value"><%= stats.streak %></span>
                            <span class="stat-label">Day Streak</span>
                        </div>
                    </div>
                </div>

                <!-- Study Activity Heatmap -->
                <div class="heatmap-card">
                    <div class="heatmap-header">
                        <div class="heatmap-title">
                            <i data-lucide="flame"></i>
                            <div>
                                <h3>Study Activity</h3>
                                <p id="heatmapSubtitle">Loading activity data...</p>
                            </div>
                        </div>
                        <div class="heatmap-legend">
                            <span class="heatmap-legend-label">Less</span>
                            <div class="heatmap-legend-cell" style="background: var(--hm-0)"></div>
                            <div class="heatmap-legend-cell" style="background: var(--hm-1)"></div>
                            <div class="heatmap-legend-cell" style="background: var(--hm-2)"></div>
                            <div class="heatmap-legend-cell" style="background: var(--hm-3)"></div>
                            <div class="heatmap-legend-cell" style="background: var(--hm-4)"></div>
                            <span class="heatmap-legend-label">More</span>
                        </div>
                    </div>
                    <div class="heatmap-scroll">
                        <div class="heatmap-months" id="heatmapMonths"></div>
                        <div class="heatmap-body">
                            <div class="heatmap-days">
                                <span></span><span>Mon</span><span></span><span>Wed</span><span></span><span>Fri</span><span></span>
                            </div>
                            <div class="heatmap-grid" id="heatmapGrid"></div>
                        </div>
                    </div>
                </div>

                <!-- Today's Smart Schedule -->
                <div class="smart-schedule-card">
                    <div class="smart-schedule-header">
                        <div class="smart-schedule-title">
                            <i data-lucide="sparkles"></i>
                            <div>
                                <h3>Today's Smart Schedule</h3>
                                <p><%= scheduleStats.todayPending %> tasks • <%= Math.round(scheduleStats.todayMinutes / 60 * 10) / 10 %>h remaining</p>
                            </div>
                        </div>
                        <div class="smart-schedule-actions">
                            <a href="/schedule/today" class="btn btn-ghost btn-sm">View All</a>
                            <form action="/schedule/generate" method="POST" style="display: inline;">
                                <input type="hidden" name="days" value="7">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i data-lucide="wand-2"></i>
                                    Generate
                                </button>
                            </form>
                        </div>
                    </div>
                    
                    <% if (typeof todayTasks !== 'undefined' && todayTasks.length > 0) { %>
                        <div class="smart-schedule-tasks">
                            <% todayTasks.forEach((task, index) => { %>
                                <div class="smart-task-item">
                                    <div class="smart-task-order"><%= index + 1 %></div>
                                    <div class="smart-task-color" style="background: <%= task.subject_color %>"></div>
                                    <div class="smart-task-info">
                                        <span class="smart-task-title"><%= task.title.replace('Study: ', '') %></span>
                                        <span class="smart-task-meta">
                                            <%= task.subject_name %> • <%= task.estimated_minutes %> min
                                        </span>
                                    </div>
                                    <div class="smart-task-actions">
                                        <a href="/study/start?topic=<%= task.topic_id %>&task=<%= task.id %>" class="btn btn-primary btn-sm">
                                            <i data-lucide="play"></i>
                                            Start
                                        </a>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                        <% if (scheduleStats.todayPending > 3) { %>
                            <div class="smart-schedule-more">
                                <a href="/schedule/today">+ <%= scheduleStats.todayPending - 3 %> more tasks</a>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="smart-schedule-empty">
                            <i data-lucide="calendar-plus"></i>
                            <p>No tasks scheduled for today</p>
                            <form action="/schedule/generate" method="POST">
                                <input type="hidden" name="days" value="7">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i data-lucide="sparkles"></i>
                                    Generate Smart Schedule
                                </button>
                            </form>
                        </div>
                    <% } %>
                </div>

                <!-- Flashcards & Practice Quick Stats -->
                <div class="flashcard-practice-row">
                    <!-- Flashcards Due Today -->
                    <div class="fc-card">
                        <div class="fc-card-icon" style="background: linear-gradient(135deg, #8b5cf6, #a78bfa);">
                            <i data-lucide="layers"></i>
                        </div>
                        <div class="fc-card-content">
                            <div class="fc-stat-row">
                                <span class="fc-stat-value"><%= typeof flashcardStats !== 'undefined' ? flashcardStats.dueToday : 0 %></span>
                                <span class="fc-stat-label">Cards Due Today</span>
                            </div>
                            <div class="fc-stat-secondary">
                                <span><%= typeof flashcardStats !== 'undefined' ? flashcardStats.totalCards : 0 %> total cards</span>
                                <span class="fc-mastery">
                                    <i data-lucide="trophy"></i>
                                    <%= typeof flashcardStats !== 'undefined' ? flashcardStats.masteryPercentage : 0 %>% mastery
                                </span>
                            </div>
                        </div>
                        <a href="/flashcards/daily" class="btn btn-primary btn-sm">
                            <i data-lucide="play"></i>
                            Review
                        </a>
                    </div>

                    <!-- Practice Quiz Stats -->
                    <div class="fc-card">
                        <div class="fc-card-icon" style="background: linear-gradient(135deg, #f59e0b, #fbbf24);">
                            <i data-lucide="brain"></i>
                        </div>
                        <div class="fc-card-content">
                            <div class="fc-stat-row">
                                <span class="fc-stat-value"><%= typeof quizStats !== 'undefined' && quizStats.recentScore !== null ? quizStats.recentScore + '%' : '--' %></span>
                                <span class="fc-stat-label">Last Quiz Score</span>
                            </div>
                            <div class="fc-stat-secondary">
                                <span><%= typeof quizStats !== 'undefined' ? quizStats.totalAttempts : 0 %> quizzes taken</span>
                                <span class="fc-avg-score">
                                    <i data-lucide="trending-up"></i>
                                    <%= typeof quizStats !== 'undefined' ? quizStats.avgScore : 0 %>% avg
                                </span>
                            </div>
                        </div>
                        <a href="/practice" class="btn btn-primary btn-sm">
                            <i data-lucide="plus"></i>
                            New Quiz
                        </a>
                    </div>
                </div>

                <div class="dashboard-grid">
                    <!-- Upcoming Tasks -->
                    <div class="card">
                        <div class="card-header">
                            <h3>
                                <i data-lucide="calendar-clock"></i>
                                Upcoming Deadlines
                            </h3>
                            <a href="/tasks" class="card-link">View All</a>
                        </div>
                        <div class="card-body">
                            <% if (upcomingTasks.length === 0) { %>
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i data-lucide="calendar-check"></i>
                                    </div>
                                    <h4>No upcoming deadlines</h4>
                                    <p>Add tasks with deadlines to see them here</p>
                                    <a href="/tasks/new" class="btn btn-primary btn-sm">
                                        <i data-lucide="plus"></i>
                                        Add Task
                                    </a>
                                </div>
                            <% } else { %>
                                <div class="tasks-list">
                                    <% upcomingTasks.forEach(task => { 
                                        const daysUntil = Math.ceil((new Date(task.deadline) - new Date()) / (1000 * 60 * 60 * 24));
                                        const isOverdue = daysUntil < 0;
                                        const isUrgent = daysUntil <= 2 && daysUntil >= 0;
                                    %>
                                        <div class="task-item <%= isOverdue ? 'overdue' : '' %>">
                                            <div class="task-checkbox">
                                                <form action="/tasks/<%= task.id %>/status" method="POST" class="status-form">
                                                    <input type="hidden" name="status" value="completed">
                                                    <button type="submit" class="checkbox-btn">
                                                        <i data-lucide="circle"></i>
                                                    </button>
                                                </form>
                                            </div>
                                            <div class="task-info">
                                                <a href="/tasks/<%= task.id %>" class="task-title"><%= task.title %></a>
                                                <div class="task-meta">
                                                    <span class="task-subject" style="--subject-color: <%= task.subject_color %>">
                                                        <%= task.subject_name %>
                                                    </span>
                                                    <span class="task-deadline <%= isOverdue ? 'overdue' : isUrgent ? 'urgent' : '' %>">
                                                        <i data-lucide="calendar"></i>
                                                        <% if (isOverdue) { %>
                                                            <%= Math.abs(daysUntil) %> day<%= Math.abs(daysUntil) !== 1 ? 's' : '' %> overdue
                                                        <% } else if (daysUntil === 0) { %>
                                                            Due today
                                                        <% } else if (daysUntil === 1) { %>
                                                            Due tomorrow
                                                        <% } else { %>
                                                            <%= daysUntil %> days left
                                                        <% } %>
                                                    </span>
                                                </div>
                                            </div>
                                            <span class="priority-badge priority-<%= task.priority %>">P<%= task.priority %></span>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="card">
                        <div class="card-header">
                            <h3>
                                <i data-lucide="zap"></i>
                                Quick Actions
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="quick-actions">
                                <a href="/study/start" class="quick-action">
                                    <div class="quick-action-icon" style="background: #dcfce7; color: #16a34a;">
                                        <i data-lucide="play-circle"></i>
                                    </div>
                                    <span>Start Session</span>
                                </a>
                                <a href="/tasks/new" class="quick-action">
                                    <div class="quick-action-icon" style="background: #dbeafe; color: #2563eb;">
                                        <i data-lucide="plus-square"></i>
                                    </div>
                                    <span>New Task</span>
                                </a>
                                <a href="/subjects/new" class="quick-action">
                                    <div class="quick-action-icon" style="background: #fef3c7; color: #d97706;">
                                        <i data-lucide="book-plus"></i>
                                    </div>
                                    <span>Add Subject</span>
                                </a>
                                <a href="/analytics" class="quick-action">
                                    <div class="quick-action-icon" style="background: #fce7f3; color: #db2777;">
                                        <i data-lucide="bar-chart-3"></i>
                                    </div>
                                    <span>Analytics</span>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Subjects Overview -->
                    <div class="card">
                        <div class="card-header">
                            <h3>
                                <i data-lucide="book-open"></i>
                                Your Subjects
                            </h3>
                            <a href="/subjects" class="card-link">View All</a>
                        </div>
                        <div class="card-body">
                            <% if (subjects.length === 0) { %>
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i data-lucide="book-plus"></i>
                                    </div>
                                    <h4>No subjects yet</h4>
                                    <p>Add your first subject to get started</p>
                                    <a href="/subjects/new" class="btn btn-primary btn-sm">
                                        <i data-lucide="plus"></i>
                                        Add Subject
                                    </a>
                                </div>
                            <% } else { %>
                                <div class="subjects-mini-grid">
                                    <% subjects.forEach(subject => { 
                                        const progress = subject.topic_count > 0 
                                            ? Math.round((parseInt(subject.completed_topics) / parseInt(subject.topic_count)) * 100) 
                                            : 0;
                                    %>
                                        <a href="/subjects/<%= subject.id %>" class="subject-mini-card" style="--subject-color: <%= subject.color %>">
                                            <div class="subject-mini-header">
                                                <div class="subject-mini-color"></div>
                                                <span class="subject-mini-name"><%= subject.name %></span>
                                            </div>
                                            <div class="subject-mini-progress">
                                                <div class="progress-bar">
                                                    <div class="progress-fill" style="width: <%= progress %>%"></div>
                                                </div>
                                                <span class="progress-text"><%= progress %>% complete</span>
                                            </div>
                                        </a>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Recent Sessions -->
                    <div class="card">
                        <div class="card-header">
                            <h3>
                                <i data-lucide="history"></i>
                                Recent Sessions
                            </h3>
                            <a href="/study/history" class="card-link">View All</a>
                        </div>
                        <div class="card-body">
                            <% if (recentSessions.length === 0) { %>
                                <div class="empty-state small">
                                    <i data-lucide="clock"></i>
                                    <p>No study sessions yet</p>
                                    <a href="/study/start" class="btn btn-primary btn-sm">Start Studying</a>
                                </div>
                            <% } else { %>
                                <div class="sessions-list">
                                    <% recentSessions.forEach(session => { %>
                                        <div class="session-row">
                                            <div class="session-color" style="background: <%= session.subject_color %>"></div>
                                            <div class="session-info">
                                                <span class="session-subject"><%= session.subject_name %></span>
                                                <span class="session-time">
                                                    <%= new Date(session.start_time).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                                                </span>
                                            </div>
                                            <div class="session-duration">
                                                <i data-lucide="clock"></i>
                                                <%= session.actual_minutes %> min
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        lucide.createIcons();

        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.querySelector('.sidebar');
        if (menuToggle) {
            menuToggle.addEventListener('click', () => sidebar.classList.toggle('open'));
        }

        document.addEventListener('click', (e) => {
            if (!sidebar.contains(e.target) && menuToggle && !menuToggle.contains(e.target)) {
                sidebar.classList.remove('open');
            }
        });
    </script>

    <style>
        /* Smart Schedule Card Styles */
        .smart-schedule-card {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            border-radius: var(--radius-xl);
            padding: var(--spacing-xl);
            margin-bottom: var(--spacing-xl);
            color: white;
        }

        .smart-schedule-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: var(--spacing-lg);
        }

        .smart-schedule-title {
            display: flex;
            align-items: flex-start;
            gap: var(--spacing-md);
        }

        .smart-schedule-title > svg {
            width: 28px;
            height: 28px;
            margin-top: 2px;
        }

        .smart-schedule-title h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0 0 0.25rem 0;
        }

        .smart-schedule-title p {
            margin: 0;
            opacity: 0.85;
            font-size: 0.875rem;
        }

        .smart-schedule-actions {
            display: flex;
            gap: var(--spacing-sm);
        }

        .smart-schedule-actions .btn-ghost {
            color: white !important;
            border-color: rgba(255,255,255,0.5);
            background: rgba(255,255,255,0.15);
        }

        .smart-schedule-actions .btn-ghost:hover {
            background: rgba(255,255,255,0.25);
            color: white !important;
        }

        .smart-schedule-actions .btn-primary {
            background: white !important;
            color: #6366f1 !important;
        }

        .smart-schedule-actions .btn-primary:hover {
            background: rgba(255,255,255,0.9) !important;
            color: #6366f1 !important;
        }

        /* Ensure button text is always visible */
        .smart-schedule-actions .btn {
            font-weight: 600 !important;
        }

        .smart-schedule-actions .btn svg {
            color: inherit !important;
        }

        .smart-schedule-tasks {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }

        .smart-task-item {
            display: flex;
            align-items: center;
            gap: var(--spacing-md);
            background: rgba(255,255,255,0.15);
            border-radius: var(--radius-lg);
            padding: var(--spacing-md) var(--spacing-lg);
            backdrop-filter: blur(10px);
        }

        .smart-task-order {
            width: 28px;
            height: 28px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.875rem;
        }

        .smart-task-color {
            width: 4px;
            height: 32px;
            border-radius: 100px;
        }

        .smart-task-info {
            flex: 1;
            min-width: 0;
        }

        .smart-task-title {
            display: block;
            font-weight: 600;
            margin-bottom: 0.125rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .smart-task-meta {
            font-size: 0.75rem;
            opacity: 0.85;
        }

        .smart-task-actions .btn {
            background: white !important;
            color: #6366f1 !important;
            padding: 0.375rem 0.75rem;
            font-weight: 600 !important;
        }

        .smart-task-actions .btn svg {
            color: #6366f1 !important;
        }

        .smart-task-actions .btn:hover {
            background: rgba(255,255,255,0.9) !important;
            transform: translateY(-1px);
        }

        .smart-schedule-more {
            text-align: center;
            margin-top: var(--spacing-md);
        }

        .smart-schedule-more a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-size: 0.875rem;
        }

        .smart-schedule-more a:hover {
            color: white;
            text-decoration: underline;
        }

        .smart-schedule-empty {
            text-align: center;
            padding: var(--spacing-xl);
        }

        .smart-schedule-empty svg {
            width: 48px;
            height: 48px;
            opacity: 0.7;
            margin-bottom: var(--spacing-md);
        }

        .smart-schedule-empty p {
            margin: 0 0 var(--spacing-md) 0;
            opacity: 0.85;
        }

        .smart-schedule-empty .btn-primary {
            background: white !important;
            color: var(--primary) !important;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-xl);
        }

        .subjects-mini-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-md);
        }

        .subject-mini-card {
            display: block;
            padding: var(--spacing-md);
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            text-decoration: none;
            border-left: 3px solid var(--subject-color);
            transition: all var(--transition-fast);
        }

        .subject-mini-card:hover {
            background: var(--bg-tertiary);
            transform: translateX(2px);
        }

        .subject-mini-header {
            display: flex;
            align-items: center;
            gap: var(--spacing-sm);
            margin-bottom: var(--spacing-sm);
        }

        .subject-mini-color {
            width: 10px;
            height: 10px;
            background: var(--subject-color);
            border-radius: 50%;
        }

        .subject-mini-name {
            font-weight: 500;
            color: var(--text-primary);
            font-size: 0.875rem;
        }

        .subject-mini-progress .progress-bar {
            height: 4px;
            margin-bottom: 0.25rem;
        }

        .subject-mini-progress .progress-text {
            font-size: 0.6875rem;
            color: var(--text-secondary);
        }

        .stat-warning {
            border: 1px solid #fbbf24;
        }

        .task-deadline.urgent {
            color: var(--warning);
            font-weight: 500;
        }

        .task-item.overdue {
            background: #fef2f2;
        }

        .tasks-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }

        .task-item {
            display: flex;
            align-items: center;
            gap: var(--spacing-md);
            padding: var(--spacing-md);
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
        }

        .checkbox-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-tertiary);
            padding: 0;
        }

        .checkbox-btn:hover {
            color: var(--success);
        }

        .task-info {
            flex: 1;
            min-width: 0;
        }

        .task-title {
            display: block;
            font-weight: 500;
            color: var(--text-primary);
            text-decoration: none;
            margin-bottom: 0.25rem;
        }

        .task-title:hover {
            color: var(--primary);
        }

        .task-meta {
            display: flex;
            align-items: center;
            gap: var(--spacing-md);
            font-size: 0.75rem;
        }

        .task-subject {
            color: var(--subject-color);
            font-weight: 500;
        }

        .task-deadline {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            color: var(--text-secondary);
        }

        .task-deadline svg {
            width: 12px;
            height: 12px;
        }

        .task-deadline.overdue {
            color: var(--danger);
        }

        .priority-badge {
            padding: 0.25rem 0.5rem;
            border-radius: var(--radius-sm);
            font-size: 0.6875rem;
            font-weight: 600;
        }

        .priority-1 { background: #fee2e2; color: #dc2626; }
        .priority-2 { background: #fef3c7; color: #d97706; }
        .priority-3 { background: #dbeafe; color: #2563eb; }
        .priority-4 { background: #e0e7ff; color: #4f46e5; }
        .priority-5 { background: #f3f4f6; color: #6b7280; }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-md);
        }

        .quick-action {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--spacing-sm);
            padding: var(--spacing-lg);
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            text-decoration: none;
            transition: all var(--transition-fast);
        }

        .quick-action:hover {
            background: var(--bg-tertiary);
            transform: translateY(-2px);
        }

        .quick-action-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .quick-action-icon svg {
            width: 24px;
            height: 24px;
        }

        .quick-action span {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-primary);
        }

        .sessions-list {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-sm);
        }

        .session-row {
            display: flex;
            align-items: center;
            gap: var(--spacing-md);
            padding: var(--spacing-md);
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
        }

        .session-color {
            width: 4px;
            height: 32px;
            border-radius: 2px;
        }

        .session-info {
            flex: 1;
        }

        .session-subject {
            display: block;
            font-weight: 500;
            color: var(--text-primary);
            font-size: 0.875rem;
        }

        .session-time {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .session-duration {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .session-duration svg {
            width: 14px;
            height: 14px;
        }

        .active-session-banner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: var(--spacing-lg);
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-radius: var(--radius-xl);
            margin-bottom: var(--spacing-xl);
        }

        .banner-content {
            display: flex;
            align-items: center;
            gap: var(--spacing-lg);
        }

        .banner-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.2);
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .banner-info h3 {
            font-size: 1rem;
            font-weight: 600;
            color: white;
            margin-bottom: 0.25rem;
        }

        .banner-info p {
            color: rgba(255,255,255,0.9);
            font-size: 0.875rem;
        }

        .active-session-banner .btn {
            background: white;
            color: #059669;
        }

        .active-session-banner .btn:hover {
            background: #f0fdf4;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .spinning {
            animation: spin 2s linear infinite;
        }

        .empty-state.small {
            padding: var(--spacing-lg);
            text-align: center;
        }

        .empty-state.small svg {
            width: 32px;
            height: 32px;
            color: var(--text-tertiary);
            margin-bottom: var(--spacing-sm);
        }

        .empty-state.small p {
            margin-bottom: var(--spacing-md);
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        /* ── Heatmap ── */
        :root {
            --hm-0: #ebedf0;
            --hm-1: #9be9a8;
            --hm-2: #40c463;
            --hm-3: #30a14e;
            --hm-4: #216e39;
        }
        [data-theme="dark"] {
            --hm-0: #161b22;
            --hm-1: #0e4429;
            --hm-2: #006d32;
            --hm-3: #26a641;
            --hm-4: #39d353;
        }

        .heatmap-card {
            background: var(--bg-primary, #fff);
            border-radius: var(--radius-lg, 12px);
            border: 1px solid var(--border-color, #e5e7eb);
            padding: var(--spacing-xl, 24px);
            margin-bottom: var(--spacing-xl, 24px);
        }

        .heatmap-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: var(--spacing-lg, 16px);
            flex-wrap: wrap;
            gap: 12px;
        }

        .heatmap-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .heatmap-title i {
            width: 24px;
            height: 24px;
            color: #f97316;
        }

        .heatmap-title h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        .heatmap-title p {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin: 2px 0 0;
        }

        .heatmap-legend {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.75rem;
            color: var(--text-tertiary);
        }

        .heatmap-legend-label {
            margin: 0 4px;
        }

        .heatmap-legend-cell {
            width: 12px;
            height: 12px;
            border-radius: 2px;
        }

        .heatmap-scroll {
            overflow-x: auto;
            padding-bottom: 4px;
        }

        .heatmap-months {
            display: flex;
            font-size: 0.7rem;
            color: var(--text-tertiary);
            padding-left: 32px;
            margin-bottom: 4px;
            min-width: max-content;
        }

        .heatmap-months span {
            display: inline-block;
        }

        .heatmap-body {
            display: flex;
            gap: 4px;
            min-width: max-content;
        }

        .heatmap-days {
            display: flex;
            flex-direction: column;
            gap: 3px;
            font-size: 0.65rem;
            color: var(--text-tertiary);
            padding-top: 0;
            width: 28px;
            flex-shrink: 0;
        }

        .heatmap-days span {
            height: 14px;
            line-height: 14px;
        }

        .heatmap-grid {
            display: grid;
            grid-template-rows: repeat(7, 14px);
            grid-auto-flow: column;
            grid-auto-columns: 14px;
            gap: 3px;
        }

        .heatmap-cell {
            width: 14px;
            height: 14px;
            border-radius: 3px;
            position: relative;
            cursor: pointer;
            transition: outline 0.15s;
            outline: 1px solid rgba(128, 128, 128, 0.15);
        }

        .heatmap-cell:hover {
            outline: 2px solid var(--text-secondary);
            outline-offset: -1px;
        }

        .heatmap-cell .hm-tip {
            display: none;
            position: absolute;
            bottom: calc(100% + 6px);
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-inverse, #1f2937);
            color: #fff;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            white-space: nowrap;
            z-index: 20;
            pointer-events: none;
            box-shadow: 0 2px 6px rgba(0,0,0,.25);
        }

        .heatmap-cell .hm-tip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 4px solid transparent;
            border-top-color: var(--bg-inverse, #1f2937);
        }

        .heatmap-cell:hover .hm-tip {
            display: block;
        }

        @media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .subjects-mini-grid,
            .quick-actions {
                grid-template-columns: 1fr;
            }

            .active-session-banner {
                flex-direction: column;
                text-align: center;
                gap: var(--spacing-lg);
            }

            .banner-content {
                flex-direction: column;
            }
        }

        /* Dark mode overrides */
        [data-theme="dark"] .priority-1 { background: #7f1d1d; color: #fca5a5; }
        [data-theme="dark"] .priority-2 { background: #78350f; color: #fcd34d; }
        [data-theme="dark"] .priority-3 { background: #1e3a5f; color: #93c5fd; }
        [data-theme="dark"] .priority-4 { background: #312e81; color: #a5b4fc; }
        [data-theme="dark"] .priority-5 { background: #334155; color: #9ca3af; }
        [data-theme="dark"] .chart-card { background: #1e293b; border-color: #334155; }
        [data-theme="dark"] .chart-header h3 { color: #f3f4f6; }
        [data-theme="dark"] .completion-popup { background: #1e293b; border-color: #334155; color: #f3f4f6; }
        [data-theme="dark"] .heatmap-title h3 { color: #f3f4f6; }
    </style>

    <script>
    (function() {
        var grid = document.getElementById('heatmapGrid');
        var monthsEl = document.getElementById('heatmapMonths');
        var subtitle = document.getElementById('heatmapSubtitle');
        if (!grid) return;

        var WEEKS = 21;
        var CELL = WEEKS * 7;
        var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

        function level(m) {
            if (m <= 0)  return 0;
            if (m < 30)  return 1;
            if (m < 60)  return 2;
            if (m < 120) return 3;
            return 4;
        }

        function pad(n) { return n < 10 ? '0' + n : n; }
        function key(d) { return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()); }
        function fmtDate(d) { return MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear(); }

        fetch('/api/heatmap').then(function(r){ return r.json(); }).then(function(json) {
            var map = {};
            if (json.success && json.data) {
                json.data.forEach(function(r) { map[r.study_date] = +r.total_minutes; });
            }

            /* Build date range ending today, starting on a Sunday */
            var today = new Date();
            today.setHours(0,0,0,0);
            var end = new Date(today);
            var start = new Date(end);
            start.setDate(start.getDate() - CELL + 1);
            /* roll start back to Sunday */
            start.setDate(start.getDate() - start.getDay());

            var activeDays = 0;
            var totalMin = 0;
            var cells = [];
            var d = new Date(start);

            while (d <= end) {
                var k = key(d);
                var m = map[k] || 0;
                if (m > 0) { activeDays++; totalMin += m; }

                var el = document.createElement('div');
                el.className = 'heatmap-cell';
                el.style.background = 'var(--hm-' + level(m) + ')';
                var tip = document.createElement('span');
                tip.className = 'hm-tip';
                tip.textContent = m > 0 ? (m + ' min on ' + fmtDate(d)) : ('No activity on ' + fmtDate(d));
                el.appendChild(tip);
                grid.appendChild(el);
                cells.push({ date: new Date(d), el: el });

                d.setDate(d.getDate() + 1);
            }

            /* Month labels */
            var weekIndex = 0;
            var lastMonth = -1;
            monthsEl.innerHTML = '';
            for (var i = 0; i < cells.length; i += 7) {
                var colDate = cells[i].date;
                var span = document.createElement('span');
                span.style.width = '17px'; /* 14px cell + 3px gap */
                if (colDate.getMonth() !== lastMonth && colDate.getDate() <= 7) {
                    span.textContent = MONTHS[colDate.getMonth()];
                    span.style.width = '17px';
                }
                lastMonth = colDate.getMonth();
                monthsEl.appendChild(span);
                weekIndex++;
            }

            var hrs = (totalMin / 60).toFixed(1);
            subtitle.textContent = activeDays + ' active day' + (activeDays !== 1 ? 's' : '') + ' \u00B7 ' + hrs + 'h total study time';
        }).catch(function() {
            subtitle.textContent = 'Unable to load activity data';
        });
    })();
    </script>
</body>
</html>
